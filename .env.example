# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                      # development | production
APP_NAME=saasguard
APP_VERSION=0.1.0
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# ── Database ───────────────────────────────────────────────────────────────────
DUCKDB_PATH=/app/data/saasguard.duckdb   # mounted volume path

# ── Model Artifacts ────────────────────────────────────────────────────────────
MODELS_DIR=/app/models

# ── LLM (Phase 5 – AI/LLM Layer) ──────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here          # get free key at console.groq.com
LLM_PROVIDER=groq                            # groq | ollama
LLM_MODEL=llama-3.1-8b-instant              # Groq: llama-3.1-8b-instant | Ollama: llama3.1:8b
OLLAMA_HOST=http://ollama:11434              # Ollama service URL (docker-compose dev profile)

# ── Apache Superset ────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=change_me_in_production_use_openssl_rand_base64_42

# ── CORS (Phase 7 – Production Deployment) ─────────────────────────────────────
ALLOWED_ORIGINS=https://your-superset.onrender.com,https://your-app.onrender.com

# ── Prometheus ─────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
