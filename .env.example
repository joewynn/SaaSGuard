# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                      # development | production
APP_NAME=saasguard
APP_VERSION=0.1.0
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# ── Database ───────────────────────────────────────────────────────────────────
DUCKDB_PATH=/app/data/saasguard.duckdb   # mounted volume path

# ── Model Artifacts ────────────────────────────────────────────────────────────
MODELS_DIR=/app/models

# ── LLM (Groq) ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama3-8b-8192

# ── Apache Superset ────────────────────────────────────────────────────────────
SUPERSET_SECRET_KEY=change_me_in_production_use_openssl_rand_base64_42

# ── Prometheus ─────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
